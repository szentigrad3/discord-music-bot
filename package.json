{
  "name": "discord-music-bot",
  "version": "1.0.0",
  "description": "A feature-rich Discord music bot with dashboard",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "deploy": "node src/deploy-commands.js",
    "dashboard": "node src/dashboard/index.js",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.0",
    "@prisma/client": "^5.14.0",
    "csrf-csrf": "^4.0.3",
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.0",
    "ffmpeg-static": "^5.2.0",
    "libsodium-wrappers": "^0.7.15",
    "opusscript": "^0.0.8",
    "passport": "^0.7.0",
    "passport-discord-auth": "^1.2.0",
    "prisma": "^5.14.0",
    "sodium-native": "^4.1.1",
    "yt-dlp-exec": "^1.0.2"
  },
  "devDependencies": {
    "patch-package": "^8.0.1"
  }
}
